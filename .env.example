# ----------------------------------------------------------------------------
# Frontend environment (Vite). Copy to ".env". Variables must start with VITE_.
# ----------------------------------------------------------------------------

# Base URL the app calls for the API.
#   • Dev (default): "/api"  → proxied to the backend by Vite
#   • Production:    https://api.yourdomain.com/api
VITE_API_URL=/api

# Dev only: where the Vite dev server proxies "/api".
VITE_API_PROXY_TARGET=http://localhost:4000
